NODE_ENV=production
PORT=10000

CLIENT_ORIGIN=https://your-vercel-production-domain
CLIENT_ORIGINS=https://your-vercel-production-domain
FRONTEND_URL=https://your-vercel-production-domain

DB_HOST=maglev.proxy.rlwy.net
DB_PORT=38380
DB_NAME=railway
DB_USER=root
DB_PASSWORD=replace-with-your-railway-password
DB_CONNECTION_LIMIT=10
DB_SSL=false

JWT_SECRET=replace-with-a-new-strong-random-secret

PYTHON_COMMAND=python3

NEWS_API_KEY=replace-with-your-news-api-key
OPENWEATHER_API_KEY=replace-with-your-openweather-api-key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=replace-with-your-gmail-address
SMTP_PASS=replace-with-your-gmail-app-password
SMTP_SECURE=true
CONTACT_RECEIVER_EMAIL=replace-with-your-contact-receiver-email

RAZORPAY_KEY_ID=replace-with-your-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-key-secret

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_URL=https://your-vercel-production-domain/customer?payment=success
STRIPE_CANCEL_URL=https://your-vercel-production-domain/customer?payment=cancelled

GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_CHAT_API_KEY=

TWILIO_ACCOUNT_SID=replace-with-your-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_API_KEY_SID=replace-with-your-twilio-api-key-sid
TWILIO_API_KEY_SECRET=replace-with-your-twilio-api-key-secret
TWILIO_VERIFY_SERVICE_SID=replace-with-your-twilio-verify-service-sid

GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_WEB_CLIENT_ID=replace-with-your-google-client-id
